{
  "name": "agentfootprint",
  "version": "6.44.0",
  "description": "The explainable agent framework — backtrack a wrong answer to the exact context that caused it (evidence, not guesses). Built on footprintjs.",
  "license": "MIT",
  "author": "Sanjay Krishna Anbalagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/footprintjs/agentfootprint.git"
  },
  "homepage": "https://footprintjs.github.io/agentfootprint/",
  "bugs": {
    "url": "https://github.com/footprintjs/agentfootprint/issues"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "agentic",
    "llm",
    "rag",
    "tool-use",
    "tool-calling",
    "multi-agent",
    "flowchart",
    "explainable-ai",
    "xai",
    "causal-trace",
    "narrative",
    "observability",
    "opentelemetry",
    "typescript",
    "react-pattern",
    "swarm",
    "orchestration",
    "footprintjs",
    "anthropic",
    "claude",
    "openai",
    "bedrock",
    "mcp",
    "a2a",
    "human-in-the-loop",
    "grounding",
    "hallucination-detection",
    "audit-trail"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules package-lock.json",
    "build": "rm -rf dist && tsc && tsc -p tsconfig.esm.json && node scripts/postbuild-esm.mjs",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=text-summary --coverage.reportsDirectory=coverage",
    "test:examples": "tsc -p examples/tsconfig.json && bash scripts/run-all-examples.sh",
    "test:examples:typecheck": "tsc -p examples/tsconfig.json",
    "examples:readme": "node scripts/generate-examples-readme.mjs",
    "examples:readme:check": "node scripts/generate-examples-readme.mjs --check",
    "example": "TSX_TSCONFIG_PATH=examples/runtime.tsconfig.json npx --yes tsx",
    "test:watch": "vitest --watch",
    "docs:api": "typedoc",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts --fix",
    "format": "prettier --config .prettierrc.js --list-different 'src/**/*.ts' 'test/**/*.ts'",
    "format:fix": "prettier --config .prettierrc.js --write 'src/**/*.ts' 'test/**/*.ts'",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "coverage:badge": "npm run test:coverage; node scripts/coverage-badge.mjs"
  },
  "files": [
    "dist/**/*",
    "!dist/test",
    "!dist/**/test-barrel*",
    "!dist/esm/**/test-barrel*",
    "ai-instructions/**/*",
    "bin/**/*",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "bin": {
    "agentfootprint-setup": "ai-instructions/setup.sh",
    "agentfootprint-lint-tools": "bin/agentfootprint-lint-tools.mjs"
  },
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./memory": {
      "import": {
        "types": "./dist/esm/memory/index.d.ts",
        "default": "./dist/esm/memory/index.js"
      },
      "require": {
        "types": "./dist/types/memory/index.d.ts",
        "default": "./dist/memory/index.js"
      }
    },
    "./llm-providers": {
      "import": {
        "types": "./dist/esm/llm-providers.d.ts",
        "default": "./dist/esm/llm-providers.js"
      },
      "require": {
        "types": "./dist/types/llm-providers.d.ts",
        "default": "./dist/llm-providers.js"
      }
    },
    "./memory-providers": {
