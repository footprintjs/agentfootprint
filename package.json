      },
      "require": {
        "types": "./dist/types/tool-providers/index.d.ts",
        "default": "./dist/tool-providers/index.js"
      }
    },
    "./security": {
      "import": {
        "types": "./dist/esm/security/index.d.ts",
        "default": "./dist/esm/security/index.js"
      },
      "require": {
        "types": "./dist/types/security/index.d.ts",
