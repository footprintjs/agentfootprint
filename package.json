{
  "name": "agentfootprint",
  "version": "1.5.0",
  "description": "The explainable agent framework — build AI agents you can explain, audit, and trust. Built on footprintjs.",
  "license": "MIT",
  "author": "Sanjay Krishna Anbalagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/footprintjs/agentfootprint.git"
  },
  "homepage": "https://footprintjs.github.io/agentfootprint/",
  "bugs": {
    "url": "https://github.com/footprintjs/agentfootprint/issues"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "agentic",
    "llm",
    "rag",
    "tool-use",
    "tool-calling",
    "multi-agent",
    "flowchart",
    "explainable-ai",
    "xai",
    "causal-trace",
    "narrative",
    "observability",
    "opentelemetry",
    "typescript",
    "react-pattern",
    "swarm",
    "orchestration",
    "footprintjs",
    "anthropic",
    "claude",
    "openai",
    "bedrock",
    "mcp",
    "a2a",
    "human-in-the-loop",
    "grounding",
    "hallucination-detection",
    "audit-trail"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules package-lock.json",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts --fix",
    "format": "prettier --config .prettierrc.js --list-different 'src/**/*.ts' 'test/**/*.ts'",
    "format:fix": "prettier --config .prettierrc.js --write 'src/**/*.ts' 'test/**/*.ts'",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "files": [
    "dist/**/*",
    "!dist/test",
    "!dist/**/test-barrel*",
    "!dist/esm/**/test-barrel*",
    "ai-instructions/**/*",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "bin": {
    "agentfootprint-setup": "ai-instructions/setup.sh"
  },
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/types/providers.barrel.d.ts",
      "import": "./dist/esm/providers.barrel.js",
      "require": "./dist/providers.barrel.js"
    },
    "./instructions": {
      "types": "./dist/types/instructions.barrel.d.ts",
      "import": "./dist/esm/instructions.barrel.js",
      "require": "./dist/instructions.barrel.js"
    },
    "./observe": {
      "types": "./dist/types/observe.barrel.d.ts",
      "import": "./dist/esm/observe.barrel.js",
      "require": "./dist/observe.barrel.js"
    },
    "./resilience": {
      "types": "./dist/types/resilience.barrel.d.ts",
      "import": "./dist/esm/resilience.barrel.js",
      "require": "./dist/resilience.barrel.js"
    },
    "./security": {
      "types": "./dist/types/security.barrel.d.ts",
      "import": "./dist/esm/security.barrel.js",
      "require": "./dist/security.barrel.js"
    },
    "./explain": {
      "types": "./dist/types/explain.barrel.d.ts",
      "import": "./dist/esm/explain.barrel.js",
      "require": "./dist/explain.barrel.js"
    },
    "./stream": {
      "types": "./dist/types/stream.barrel.d.ts",
      "import": "./dist/esm/stream.barrel.js",
      "require": "./dist/stream.barrel.js"
    }
  },
  "typesVersions": {
    "*": {
      "providers": [
        "dist/types/providers.barrel.d.ts"
      ],
      "instructions": [
        "dist/types/instructions.barrel.d.ts"
      ],
      "observe": [
        "dist/types/observe.barrel.d.ts"
      ],
      "resilience": [
        "dist/types/resilience.barrel.d.ts"
      ],
      "security": [
        "dist/types/security.barrel.d.ts"
      ],
      "explain": [
        "dist/types/explain.barrel.d.ts"
      ],
      "stream": [
        "dist/types/stream.barrel.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "dependencies": {
    "footprintjs": ">=4.7.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@aws-sdk/client-bedrock-runtime": ">=3.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@aws-sdk/client-bedrock-runtime": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^6.15.0",
    "footprintjs": "file:../footPrint",
    "prettier": "^2.8.1",
    "typescript": "~5.4.5",
    "vitest": "^4.0.18",
    "zod": "^3.25.76"
  }
}
