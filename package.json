      ],
      "locales": [
        "./dist/types/locales/index.d.ts"
      ],
      "status": [
        "./dist/types/status.d.ts"
      ]
    }
  },
  "sideEffects": [
    "**/cache/strategies/*.js",
    "**/cache/index.js"
  ],
