{
  "name": "agentfootprint",
  "version": "2.9.0",
  "description": "The explainable agent framework — build AI agents you can explain, audit, and trust. Built on footprintjs.",
  "license": "MIT",
  "author": "Sanjay Krishna Anbalagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/footprintjs/agentfootprint.git"
  },
  "homepage": "https://footprintjs.github.io/agentfootprint/",
  "bugs": {
    "url": "https://github.com/footprintjs/agentfootprint/issues"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "agentic",
    "llm",
    "rag",
    "tool-use",
    "tool-calling",
    "multi-agent",
    "flowchart",
    "explainable-ai",
    "xai",
    "causal-trace",
    "narrative",
    "observability",
    "opentelemetry",
    "typescript",
    "react-pattern",
    "swarm",
    "orchestration",
    "footprintjs",
    "anthropic",
    "claude",
    "openai",
    "bedrock",
    "mcp",
    "a2a",
    "human-in-the-loop",
    "grounding",
    "hallucination-detection",
    "audit-trail"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage node_modules package-lock.json",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:examples": "tsc -p examples/tsconfig.json && bash scripts/run-all-examples.sh",
    "test:examples:typecheck": "tsc -p examples/tsconfig.json",
    "examples:readme": "node scripts/generate-examples-readme.mjs",
    "examples:readme:check": "node scripts/generate-examples-readme.mjs --check",
    "example": "TSX_TSCONFIG_PATH=examples/runtime.tsconfig.json npx --yes tsx",
    "test:watch": "vitest --watch",
    "docs:api": "typedoc",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --ext .ts --fix",
    "format": "prettier --config .prettierrc.js --list-different 'src/**/*.ts' 'test/**/*.ts'",
    "format:fix": "prettier --config .prettierrc.js --write 'src/**/*.ts' 'test/**/*.ts'",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "files": [
    "dist/**/*",
    "!dist/test",
    "!dist/**/test-barrel*",
    "!dist/esm/**/test-barrel*",
    "ai-instructions/**/*",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "bin": {
    "agentfootprint-setup": "ai-instructions/setup.sh"
  },
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/types/memory/index.d.ts",
      "import": "./dist/esm/memory/index.js",
      "require": "./dist/memory/index.js"
    },
    "./providers": {
      "types": "./dist/types/providers.d.ts",
      "import": "./dist/esm/providers.js",
      "require": "./dist/providers.js"
    },
    "./llm-providers": {
      "types": "./dist/types/llm-providers.d.ts",
      "import": "./dist/esm/llm-providers.js",
      "require": "./dist/llm-providers.js"
    },
    "./memory-providers": {
      "types": "./dist/types/memory-providers.d.ts",
      "import": "./dist/esm/memory-providers.js",
      "require": "./dist/memory-providers.js"
    },
    "./observability-providers": {
      "types": "./dist/types/observability-providers.d.ts",
      "import": "./dist/esm/observability-providers.js",
      "require": "./dist/observability-providers.js"
    },
    "./observe": {
      "types": "./dist/types/observe.d.ts",
      "import": "./dist/esm/observe.js",
      "require": "./dist/observe.js"
    },
    "./resilience": {
      "types": "./dist/types/resilience/index.d.ts",
      "import": "./dist/esm/resilience/index.js",
      "require": "./dist/resilience/index.js"
    },
    "./stream": {
      "types": "./dist/types/stream.d.ts",
      "import": "./dist/esm/stream.js",
      "require": "./dist/stream.js"
    },
    "./injection-engine": {
      "types": "./dist/types/injection-engine.d.ts",
      "import": "./dist/esm/injection-engine.js",
      "require": "./dist/injection-engine.js"
    },
    "./memory-redis": {
      "types": "./dist/types/adapters/memory/redis.d.ts",
      "import": "./dist/esm/adapters/memory/redis.js",
      "require": "./dist/adapters/memory/redis.js"
    },
    "./memory-agentcore": {
      "types": "./dist/types/adapters/memory/agentcore.d.ts",
      "import": "./dist/esm/adapters/memory/agentcore.js",
      "require": "./dist/adapters/memory/agentcore.js"
    },
    "./tool-providers": {
      "types": "./dist/types/tool-providers/index.d.ts",
      "import": "./dist/esm/tool-providers/index.js",
      "require": "./dist/tool-providers/index.js"
    },
    "./security": {
      "types": "./dist/types/security/index.d.ts",
      "import": "./dist/esm/security/index.js",
      "require": "./dist/security/index.js"
    },
    "./locales": {
      "types": "./dist/types/locales/index.d.ts",
      "import": "./dist/esm/locales/index.js",
      "require": "./dist/locales/index.js"
    },
    "./status": {
      "types": "./dist/types/status.d.ts",
      "import": "./dist/esm/status.js",
      "require": "./dist/status.js"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "@aws-sdk/client-bedrock-agent-runtime": "*",
    "@aws-sdk/client-bedrock-runtime": "*",
    "@aws-sdk/client-cloudwatch-logs": "*",
    "@aws-sdk/client-xray": "*",
    "@modelcontextprotocol/sdk": "*",
    "@opentelemetry/api": "*",
    "footprintjs": ">=4.17.1",
    "ioredis": "*",
    "openai": "*",
    "zod": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@aws-sdk/client-bedrock-runtime": {
      "optional": true
    },
    "@aws-sdk/client-bedrock-agent-runtime": {
      "optional": true
    },
    "@aws-sdk/client-cloudwatch-logs": {
      "optional": true
    },
    "@aws-sdk/client-xray": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^6.15.0",
    "footprintjs": "^4.17.1",
    "prettier": "^2.8.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~5.4.5",
    "vitest": "^4.1.5",
    "zod": "^3.25.76"
  }
}
