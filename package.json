      "require": {
        "types": "./dist/types/status.d.ts",
        "default": "./dist/status.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "memory": [
        "./dist/types/memory/index.d.ts"
      ],
      "llm-providers": [
        "./dist/types/llm-providers.d.ts"
      ],
      "memory-providers": [
        "./dist/types/memory-providers.d.ts"
      ],
      "strategies": [
        "./dist/types/strategies/index.d.ts"
      ],
      "observability-providers": [
        "./dist/types/observability-providers.d.ts"
      ],
      "observe": [
        "./dist/types/observe.d.ts"
      ],
      "observability/contextError/finders": [
        "./dist/types/observability/contextError/finders/index.d.ts"
      ],
      "resilience": [
