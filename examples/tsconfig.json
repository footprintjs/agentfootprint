{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "agentfootprint": ["../src/index.ts"],
      "agentfootprint/providers": ["../src/providers.barrel.ts"],
      "agentfootprint/observe": ["../src/observe.barrel.ts"],
      "agentfootprint/instructions": ["../src/instructions.barrel.ts"]
    }
  },
  "include": ["**/*.ts"]
}
