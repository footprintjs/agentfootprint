{
  "name": "footprint-explainable-ui",
  "version": "0.22.0",
  "description": "Themeable React components for visualizing FootPrint pipeline execution",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./flowchart": {
      "types": "./dist/flowchart.d.ts",
      "import": "./dist/flowchart.js",
      "require": "./dist/flowchart.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "flowchart": [
        "./dist/flowchart.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=text-summary --coverage.reportsDirectory=coverage",
    "coverage:badge": "npm run test:coverage; node scripts/coverage-badge.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@xyflow/react": "^12.10.2",
    "jsdom": "^29.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/footprintjs/explainable-ui.git"
  },
  "keywords": [
    "footprint",
    "pipeline",
    "visualization",
    "debugging",
    "react",
    "time-travel",
    "explainable-ai"
  ],
  "dependencies": {
    "dagre": "^0.8.5"
  }
}
