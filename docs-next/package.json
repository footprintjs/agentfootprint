{
  "name": "agentfootprint-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:api": "node ../scripts/gen-fumadocs-api.mjs",
    "gen:flowchart": "node scripts/gen-agent-flowchart.mjs",
    "gen:replay": "node scripts/gen-replay-trace.mjs",
    "check:api": "node ../scripts/gen-fumadocs-api.mjs && git -C .. diff --exit-code -- docs-next/content/docs/api",
    "check:links": "node ../scripts/check-doc-links.mjs --strict",
    "predev": "node ../scripts/gen-fumadocs-api.mjs && node scripts/gen-agent-flowchart.mjs && node scripts/gen-replay-trace.mjs",
    "dev": "next dev",
    "prebuild": "node ../scripts/gen-fumadocs-api.mjs && node scripts/gen-agent-flowchart.mjs && node scripts/gen-replay-trace.mjs",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.11.0",
    "agentfootprint": "file:..",
    "agentfootprint-lens": "^0.23.8",
    "footprint-explainable-ui": "^0.25.2",
    "footprintjs": "^9.9.0",
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-ui": "^16.10.5",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "twoslash": "^0.3.8",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
